{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NamAsta Diagnostics",
  "version": "1.0.2",
  "identifier": "com.namansharma.scl-lab-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NamAsta Diagnostics",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "NamAsta Diagnostics",
    "copyright": "© NamAsta Diagnostics",
    "category": "Medical",
    "shortDescription": "Pathology lab management & reporting",
    "longDescription": "NamAsta Diagnostics — offline-first laboratory management: patient registration, result entry, approval-locked reports, and WhatsApp/email/print delivery.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/namansh70747/scl-lab-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBM0E0NkQ1OTkwQ0QxREIKUldUYjBReVoxVVk2V3ExYmFTak5iTzJuYVVrVENVU2lBNEc1MklNeGUxaVBzdkoybCtVbWNEalIK"
    }
  }
}
